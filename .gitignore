# ============================================================
# .gitignore — Light of Jesus Pastoral Care Center (LojPCC)
# ============================================================

# ── Media & large binary assets (add your own copies locally) ──
*.mp4
*.webm
*.mov
*.avi
*.mkv
*.gif
# If you want to track the logo WebP, comment the line below out
*.webp

# ── OS generated files ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor & IDE files ──
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ── Node / npm (if a dev server or tooling is ever added) ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ── Environment / secrets ──
.env
.env.local
.env.*.local
secrets.js
config.local.js

# ── Build output (if a bundler is added later) ──
dist/
build/
.cache/

# ── Logs ──
*.log
logs/

# ── Temporary files ──
tmp/
temp/
*.tmp
*.bak
*.orig
